@model IEnumerable<BookingSportsField.Models.Facility>

@{
    ViewData["Title"] = "Danh sách Cơ Sở";
}

<h1 class="text-center text-dark mb-4">DANH SÁCH CƠ SỞ</h1>

<table id="facilityTable" class="table table-striped table-bordered" style="width: 100%;">
    <thead>
        <tr>
            <th>Tên cơ sở</th>
            <th style ="width: 200px;">Địa chỉ</th>
            <th>Mở cửa</th>
            <th>Đóng cửa</th>
            <th>Chủ sân</th>
            <th>Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Address)</td>
                <td>@item.OpeningTime.ToString(@"hh\:mm")</td>
                <td>@item.ClosingTime.ToString(@"hh\:mm")</td>
                <td>@Html.DisplayFor(modelItem => item.FieldOwner.Email)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Chi tiết</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#facilityTable').DataTable({
                "paging": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "lengthChange": false,
                "pageLength": 5,
                "language": {
                    "search": "Tìm kiếm:",
                    "lengthMenu": "Hiển thị _MENU_ mục mỗi trang",
                    "info": "Hiển thị _START_ đến _END_ trong tổng số _TOTAL_ mục",
                    "infoEmpty": "Không có dữ liệu",
                    "infoFiltered": "(Lọc từ _MAX_ mục)",
                    "paginate": {
                        "previous": "Trước",
                        "next": "Tiếp theo"
                    }
                }
            });
        });
    </script>
}
