@model IEnumerable<BookingSportsField.Models.Booking>
@using System.Globalization
@{
    ViewData["Title"] = "Index";
}

<h1 class="text-center text-success-emphasis">DANH SÁCH ĐẶT SÂN</h1>

<!-- DataTable container -->
<table id="bookingTable" class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Người đặt</th>
            <th>Tên sân</th>
            <th>Tên cơ sở</th>
            <th>Ngày đặt</th>
            <th>Giờ bắt đầu</th>
            <th>Giờ kết thúc</th>
            <th>Thành tiền</th>
            <th>Tình trạng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.User.Email)</td>
                <td>@Html.DisplayFor(modelItem => item.Field.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Field.Facility.Name)</td>
                <td data-order ="@item.BookingDate.ToString("yyyy-MM-dd")">@Html.DisplayFor(modelItem => item.BookingDate)</td>
                <td>@item.StartTime.ToString(@"hh\:mm")</td>
                <td>@item.EndTime.ToString(@"hh\:mm")</td>
                <td>@item.TotalPrice.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))</td>
                <td>@Html.DisplayFor(modelItem => item.Status)</td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    @* Include jQuery and DataTables JS & CSS *@
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            // Initialize DataTable
            $('#bookingTable').DataTable({
                "paging": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "lengthChange": false,
                "pageLength": 10, // Set number of rows per page
                "language": {
                    "search": "Tìm kiếm:",
                    "lengthMenu": "Hiển thị _MENU_ mục mỗi trang",
                    "info": "Hiển thị _START_ đến _END_ trong tổng số _TOTAL_ mục",
                    "infoEmpty": "Không có dữ liệu",
                    "infoFiltered": "(Lọc từ _MAX_ mục)",
                    "paginate": {
                        "previous": "Trước",
                        "next": "Tiếp theo"
                    }
                }
            });
        });
    </script>
}
