@{
    ViewData["Title"] = "Trang quản trị";
    // Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-5">
    <h2 class="text-center fw-bold text-success-emphasis mb-4">TRANG QUẢN TRỊ HỆ THỐNG</h2>

    <div class="row g-4">
        <!-- Quản lý cơ sở -->
        <div class="col-md-4">
            <a class="text-decoration-none text-dark" asp-area="Admin" asp-controller="Facility" asp-action="Index">
                <div class="card shadow h-100 text-center admin-card hover-shadow">
                    <div class="card-body">
                        <i class="bi bi-building fs-1 text-primary mb-3"></i>
                        <h5 class="card-title fw-bold">Quản lý cơ sở</h5>
                        <p class="card-text text-muted small">Thêm, sửa, xóa và duyệt các cơ sở sân thể thao.</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a class="text-decoration-none text-dark" asp-area="Admin" asp-controller="Facility" asp-action="Pending">
                <div class="card shadow h-100 text-center admin-card hover-shadow">
                    <div class="card-body position-relative">
                        <i class="bi bi-hourglass-split fs-1 text-secondary mb-3"></i>

                        @if (ViewBag.PendingFacilityCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @ViewBag.PendingFacilityCount
                            </span>
                        }

                        <h5 class="card-title fw-bold">Duyệt cơ sở</h5>
                        <p class="card-text text-muted small">Xem danh sách các cơ sở đang chờ phê duyệt.</p>
                    </div>
                </div>
            </a>
        </div>
        <!-- Quản lý đặt sân -->
        <div class="col-md-4">
            <a class="text-decoration-none text-dark" asp-area="Admin" asp-controller="Booking" asp-action="Index">
                <div class="card shadow h-100 text-center admin-card hover-shadow">
                    <div class="card-body">
                        <i class="bi bi-calendar-check fs-1 text-danger mb-3"></i>
                        <h5 class="card-title fw-bold">Lịch đặt sân</h5>
                        <p class="card-text text-muted small">Xem tất cả lịch đặt sân, trạng thái và chi tiết.</p>
                    </div>
                </div>
            </a>
        </div>
        <!-- Thống kê -->
        <div class="col-md-4">
            <a class="text-decoration-none text-dark" asp-area="Admin" asp-controller="Statistic" asp-action="Index">
                <div class="card shadow h-100 text-center admin-card hover-shadow">
                    <div class="card-body">
                        <i class="bi bi-bar-chart-line fs-1 text-info mb-3"></i>
                        <h5 class="card-title fw-bold">Thống kê</h5>
                        <p class="card-text text-muted small">Doanh thu, lượng đặt sân, người dùng theo tháng.</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Quản lý người dùng -->
        <div class="col-md-4">
            <a class="text-decoration-none text-dark" asp-area="Admin" asp-controller="User" asp-action="Index">
                <div class="card shadow h-100 text-center admin-card hover-shadow">
                    <div class="card-body">
                        <i class="bi bi-people fs-1 text-warning mb-3"></i>
                        <h5 class="card-title fw-bold">Người dùng</h5>
                        <p class="card-text text-muted small">Xem và quản lý tài khoản khách hàng, chủ sân.</p>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>

<style>
    .admin-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border-radius: 12px;
    }

        .admin-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
        }
</style>