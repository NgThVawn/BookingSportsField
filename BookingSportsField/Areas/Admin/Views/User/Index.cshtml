@model List<BookingSportsField.ViewModels.UserWithRolesViewModel>

@{
    ViewData["Title"] = "Quản lý người dùng";
}

@{
    Func<string, string> translateRole = role =>
    {
        return role switch
        {
            "Admin" => "Quản trị viên",
            "FieldOwner" => "Chủ sân",
            "Customer" => "Người dùng",
            _ => role
        };
    };
}

<h2 class="fw-bold text-success-emphasis text-center ">DANH SÁCH NGƯỜI DÙNG</h2>

<div class="table-responsive">
    <table id="userTable" class="table table-striped table-bordered align-middle" style="width:100%">
        <thead class="table-primary">
            <tr>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th class="text-center">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.User.Email</td>
                    <td>@string.Join(", ", item.Roles.Select(r => translateRole(r)))</td>
                    <td>
                        @if (item.IsLocked)
                        {
                            <span class="badge bg-danger">Bị khóa</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                    </td>
                    <td class="text-center">
                        <a href="@Url.Action("EditRole", new { id = item.User.Id })" class="btn btn-sm btn-warning mb-1">
                            <i class="bi bi-pencil-square"></i> Sửa vai trò
                        </a>

                        @if (!item.IsLocked)
                        {
                            <form asp-action="Lock" asp-route-id="@item.User.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc muốn khóa tài khoản này?');">
                                <button type="submit" class="btn btn-sm btn-dark mb-1">
                                    <i class="bi bi-lock-fill"></i> Khóa
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Unlock" asp-route-id="@item.User.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc muốn mở khóa tài khoản này?');">
                                <button type="submit" class="btn btn-sm btn-success mb-1">
                                    <i class="bi bi-unlock-fill"></i> Mở khóa
                                </button>
                            </form>
                        }

                        <form asp-action="Delete" asp-route-id="@item.User.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này không?');">
                            <button type="submit" class="btn btn-sm btn-danger mb-1">
                                <i class="bi bi-trash-fill"></i> Xóa
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<button type="button" class="btn btn-secondary mx-2" onclick="window.location.href='@Url.Action("Index", "Dashboard")'">Quay lại</button>
<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@section Scripts {
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#userTable').DataTable({
                language: {
                    search: "Tìm kiếm:",
                    lengthMenu: "Hiển thị _MENU_ mục",
                    info: "Hiển thị _START_ đến _END_ của _TOTAL_ mục",
                    paginate: {
                        first: "Đầu",
                        last: "Cuối",
                        next: "›",
                        previous: "‹"
                    },
                    zeroRecords: "Không tìm thấy kết quả",
                    infoEmpty: "Không có mục nào",
                    infoFiltered: "(lọc từ _MAX_ mục)"
                }
            });
        });
    </script>
}
