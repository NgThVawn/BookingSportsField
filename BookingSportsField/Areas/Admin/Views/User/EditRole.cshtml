@model BookingSportsField.ViewModels.EditUserRoleViewModel

@{
    ViewData["Title"] = "Sửa vai trò";
    // Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
@{
    var roleOptions = Model.AllRoles.Select(r => new SelectListItem
            {
                Value = r,
                Text = r switch
                {
                    "Admin" => "Quản trị viên",
                    "FieldOwner" => "Chủ sân",
                    "Customer" => "Người dùng",
                    _ => r
                },
                Selected = r == Model.SelectedRole
            }).ToList();
}

<h2 class="text-primary fw-bold">Phân quyền người dùng</h2>

<form asp-action="EditRole" method="post">
    <input type="hidden" asp-for="UserId" />

    <div class="mb-3">
        <label>Email</label>
        <input type="text" class="form-control" value="@Model.Email" disabled />
    </div>

    <div class="mb-3">
        <label>Chọn vai trò</label>
        <select asp-for="SelectedRole" asp-items="roleOptions" class="form-select"></select>
    </div>

    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
