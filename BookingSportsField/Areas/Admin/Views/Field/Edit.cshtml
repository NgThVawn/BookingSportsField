@model BookingSportsField.Models.Field
<h4 class="text-center text-dark mb-4">Chỉnh sửa sân bóng</h4>
<form asp-action="Edit" method="post" class="container mt-4">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="FacilityId" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Tên sân</label>
        <input asp-for="Name" class="form-control" placeholder="Nhập tên sân" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Type" class="form-label">Loại sân</label>
        <select asp-for="Type" asp-items="Html.GetEnumSelectList<FieldType>()" class="form-select">
            <option value="">Chọn loại sân</option>
        </select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PricePerHour" class="form-label">Giá mỗi giờ (VND)</label>
        <input asp-for="PricePerHour" class="form-control" type="number" step="10000" placeholder="Nhập giá mỗi giờ" />
        <span asp-validation-for="PricePerHour" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-between">
        <a asp-controller="Field" asp-action="Index" asp-route-facilityId="@Model.FacilityId" class="btn btn-secondary">Quay lại</a>
        <button type="submit" class="btn btn-primary">Cập nhật</button>
    </div>
</form>
