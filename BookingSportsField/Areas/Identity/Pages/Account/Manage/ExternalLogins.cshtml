@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "Đăng nhập bằng tài khoản khác";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<h3 class="mb-4 text-success-emphasis fw-bold"><i class="bi bi-shield-lock me-2"></i>@ViewData["Title"]</h3>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <div class="card shadow-lg border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                @if (Model.CurrentLogins?.Count > 0)
                {
                    <h5 class="fw-semibold mb-3"><i class="bi bi-key me-1"></i> Các đăng nhập đã liên kết</h5>
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Nhà cung cấp</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var login in Model.CurrentLogins)
                            {
                                <tr>
                                    <td>@login.ProviderDisplayName</td>
                                    <td class="text-end">
                                        @if (Model.ShowRemoveButton)
                                        {
                                            <form asp-page-handler="RemoveLogin" method="post" class="d-inline">
                                                <input type="hidden" name="LoginProvider" value="@login.LoginProvider" />
                                                <input type="hidden" name="ProviderKey" value="@login.ProviderKey" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Gỡ
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Không thể gỡ</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">Bạn chưa liên kết đăng nhập bằng dịch vụ ngoài nào.</p>
                }
            </div>
        </div>

        @if (Model.OtherLogins?.Count > 0)
        {
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3"><i class="bi bi-link-45deg me-1"></i> Thêm phương thức đăng nhập khác</h5>
                    <form asp-page-handler="LinkLogin" method="post">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var provider in Model.OtherLogins)
                            {
                                <button type="submit" class="btn btn-outline-success" name="provider" value="@provider.Name">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
