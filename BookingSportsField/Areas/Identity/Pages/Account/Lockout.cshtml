@page
@model LockoutModel
@{
    ViewData["Title"] = "Tài khoản bị khóa";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-body text-center">
                    <i class="bi bi-lock-fill display-3 text-danger mb-3"></i>
                    <h2 class="text-danger mb-3">Tài khoản đã bị khóa</h2>
                    <p class="text-muted">
                        Tài khoản của bạn đã bị khóa tạm thời.
                        <br />
                        Vui lòng thử lại sau hoặc liên hệ với quản trị viên để được hỗ trợ.
                    </p>
                    <a href="/" class="btn btn-outline-secondary mt-3">
                        <i class="bi bi-arrow-left"></i> Quay lại trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
