@model BookingSportsField.Models.Field

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-4">
    <h1 class="text-center text-danger">Xóa Sân</h1>

    <h3 class="text-center">Bạn chắc chắn muốn xóa sân này không?</h3>

    <div class="card shadow-sm p-4">
        <h4 class="text-secondary">Thông tin sân</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Tên sân</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

            <dt class="col-sm-3">Loại sân</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Type)</dd>

            <dt class="col-sm-3">Mã cơ sở</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.FacilityId)</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-danger">Xóa sân</button>
                <a asp-controller="Field" asp-action="Index" asp-route-facilityId="@Model.FacilityId" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>
