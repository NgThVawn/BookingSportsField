@model List<BookingSportsField.Models.Field>

@{
    ViewData["Title"] = "Danh sách sân";
    var facilityName = ViewBag.FacilityName as string;
}

<div class="container mt-4">
    <h2 class="text-center mb-4">DANH SÁCH SÂN TẠI CƠ SỞ: <span class="text-danger fw-bold">@facilityName.ToUpper()</span></h2>

    <div class="mb-3">
        <a asp-controller="Field" asp-action="Create" asp-route-facilityId="@ViewBag.FacilityId" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm sân mới
        </a>
    </div>

    <div class="card shadow-lg p-3">
        <table id="fieldsTable" class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Tên sân</th>
                    <th>Loại sân</th>
                    <th>Giá/giờ</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var field in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@field.Name</td>
                            <td>@field.Type.GetDisplayName()</td>
                            <td class="text-danger fw-bold">@field.PricePerHour.ToString("N0") VND</td>
                            <td class="fw-bold @(field.IsActive ? "text-success" : "text-secondary")">
                                @(field.IsActive ? "Đang hoạt động" : "Ngừng hoạt động")
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@field.Id" class="btn btn-sm btn-warning">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@field.Id" class="btn btn-sm btn-danger">Xóa</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>

        </table>
    </div>

    <a asp-controller="Facility" asp-action="Details" asp-route-id="@ViewBag.FacilityId" class="btn btn-secondary mt-4">
        <i class="bi bi-arrow-left"></i> Quay lại chi tiết cơ sở
    </a>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#fieldsTable').DataTable({
                "paging": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "lengthMenu": [5, 10, 25, 50],
                "columnDefs": [
                    { "orderable": false, "targets": 3 } // Không sắp xếp cột chức năng
                ],
                "language": {
                    "lengthMenu": "Hiển thị _MENU_ sân",
                    "zeroRecords": "Không tìm thấy sân phù hợp",
                    "info": "Hiển thị _START_ đến _END_ của _TOTAL_ sân",
                    "infoEmpty": "Không có sân",
                    "infoFiltered": "(lọc từ _MAX_ sân)",
                    "search": "Tìm kiếm:",
                    "paginate": {
                        "first": "Đầu",
                        "last": "Cuối",
                        "next": "Tiếp",
                        "previous": "Trước"
                    }
                }
            });
        });
    </script>
}
