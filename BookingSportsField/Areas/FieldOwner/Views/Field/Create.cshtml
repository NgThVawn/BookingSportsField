@model BookingSportsField.Models.Field

@{
    ViewData["Title"] = "Thêm Sân Mới";
}

<div class="container mt-5">
    <h1 class="text-center mb-4 text-success-emphasis">Thêm Sân Mới</h1>

    <div class="card shadow-lg p-4">
        <h4 class="text-secondary">Thông tin sân</h4>
        <hr />

        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="FacilityId" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label">Tên sân</label>
                <input asp-for="Name" class="form-control" placeholder="Nhập tên sân" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Type" class="form-label">Loại sân</label>
                <select asp-for="Type" asp-items="(IEnumerable<SelectListItem>)ViewBag.FieldTypes" class="form-control">
                    <option value="">Chọn loại sân</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PricePerHour" class="form-label">Giá mỗi giờ (VND)</label>
                <input asp-for="PricePerHour" type="number" step="10000" class="form-control" placeholder="Nhập giá mỗi giờ" />
                <span asp-validation-for="PricePerHour" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Thêm sân</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
