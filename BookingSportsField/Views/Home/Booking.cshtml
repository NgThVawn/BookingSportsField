@model BookingSportsField.Models.Facility
@using BookingSportsField.Models
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center fw-bold">
        @TempData["Error"]
    </div>
}
@{
    string MainImage = Model.Images?.First().ImageUrl;
    int OpenTime = Model.OpeningTime.Hours;
    int CloseTime = Model.ClosingTime.Hours == 0 ? 24 : Model.ClosingTime.Hours;
    double avgRating = Model.Reviews?.Any() == true ? Model.Reviews.Average(r => r.Rating) : 0.0;
    var roundedAvgRating = Math.Round(avgRating * 2) / 2;
}
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />
<style>
    .img-hover-zoom:hover {
        transform: scale(1.05);
        transition: transform 0.3s ease-in-out;
    }

    .review-card:hover {
        background-color: #f8f9fa;
        transition: background-color 0.3s;
    }

    .select2 {
        border-radius: 0.375rem !important;
    }
</style>

<section class="py-5 bg-light">
    <div class="container">
        <div class="row gx-5 align-items-start">
            <!-- Hình ảnh chính và thumbnails -->
            <aside class="col-lg-6">
                <div class="border rounded-4 shadow-sm mb-4 overflow-hidden position-relative">
                    <img style="max-width: 100%; max-height: 100vh; margin: auto;" class="rounded-4 fit" src="@MainImage" />
                </div>
                <div class="d-flex justify-content-center flex-wrap gap-2">
                    @foreach (var img in Model.Images)
                    {
                        <img class="thumbnail border border-secondary-subtle rounded-2 shadow-sm img-thumbnail"
                             width="70"
                             height="70"
                             style="cursor: pointer; object-fit: cover; transition: transform 0.2s;"
                             onmouseover="this.style.transform='scale(1.1)'"
                             onmouseout="this.style.transform='scale(1)'"
                             src="@img.ImageUrl" />
                    }
                </div>
            </aside>

            <!-- Thông tin cơ sở -->
            <main class="col-lg-6">
                <div class="ps-lg-3">
                    <h2 class="text-success-emphasis fw-bold mb-3 animate__animated animate__fadeInDown">@Model.Name</h2>

                    <!-- Đánh giá sao -->
                    <div class="d-flex align-items-center mb-3">
                        <div class="text-warning fs-5 me-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= roundedAvgRating)
                                {
                                    <i class="fas fa-star"></i>
                                }
                                else if (i - 0.5 == roundedAvgRating)
                                {
                                    <i class="fas fa-star-half-alt"></i>
                                }
                                else
                                {
                                    <i class="far fa-star"></i>
                                }
                            }
                        </div>
                        <span class="text-muted">@roundedAvgRating / 5</span>
                    </div>

                    <!-- Địa chỉ -->
                    <p class="mb-2">
                        <i class="fas fa-map-marker-alt text-danger me-2"></i>
                        <strong>Địa chỉ:</strong> @Model.Address
                    </p>

                    <!-- Giờ hoạt động -->
                    <p class="mb-4">
                        <i class="fas fa-clock text-warning me-2"></i>
                        <strong>Giờ hoạt động:</strong> @Model.OpeningTime.ToString(@"hh\:mm") - @Model.ClosingTime.ToString(@"hh\:mm")
                    </p>

                    <!-- Nút yêu thích -->
                    <button class="btn btn-outline-danger rounded-pill d-inline-flex align-items-center mb-4"
                            id="favorite-@Model.Id"
                            onclick="toggleFavorite(@Model.Id)">
                        <i class="fa@(ViewBag.IsFavorite ? "-solid" : "-regular") fa-heart me-2"></i>
                        Yêu thích
                    </button>

                    <!-- Bản đồ -->
                    <div class="rounded-4 overflow-hidden shadow-sm">
                        <iframe width="100%"
                                height="300"
                                frameborder="0"
                                style="border:0"
                                allowfullscreen
                                referrerpolicy="no-referrer-when-downgrade"
                                src="https://www.google.com/maps?q=@(Uri.EscapeDataString(Model.Address))&output=embed">
                        </iframe>
                    </div>
                </div>
            </main>
        </div>
    </div>
</section>
<!-- content -->
<section class="bg-light border-top py-5">
    <div class="container">
        <div class="row gx-4">
            <!-- PHẦN FORM ĐẶT SÂN -->
            <div class="col-lg-8 mb-4">
                <div class="border rounded-3 p-4 bg-white shadow-sm">
                    <h4 class="fw-bold text-center mb-4 text-success-emphasis">
                        <i class="fas fa-futbol"></i> Đặt sân
                    </h4>
                    <form id="bookingForm" class="p-4 border rounded bg-light shadow-sm">
                        <!-- Ngày -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Chọn ngày:</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                                <input type="date" id="bookingDate" name="bookingDate"
                                       class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>
                        </div>

                        <!-- Giờ bắt đầu và kết thúc -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label h5">Chọn giờ bắt đầu:</label>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-clock fa-lg"></i>
                                    <select id="startHour" name="startHour" class="form-select select2 w-100" required>
                                        @for (int i = OpenTime; i <= CloseTime - 2; i++)
                                        {
                                            <option value="@i">@i:00</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <!-- Cột chọn giờ kết thúc -->
                            <div class="col-md-6">
                                <label class="form-label h5">Chọn giờ kết thúc:</label>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-clock fa-lg"></i>
                                    <select id="endHour" name="endHour" class="form-select select2 w-100" required>
                                        @for (int i = OpenTime + 1; i <= CloseTime - 1; i++)
                                        {
                                            <option value="@i">@i:00</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Loại sân -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Loại sân:</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-layer-group"></i></span>
                                <select id="fieldType" name="fieldType" class="form-select" required>
                                    <option value="">-- Chọn loại sân --</option>
                                    <option value="FiveArtificial">Sân 5 người nhân tạo</option>
                                    <option value="SevenArtificial">Sân 7 người nhân tạo</option>
                                    <option value="FiveIndoor">Sân 5 người trong nhà</option>
                                </select>
                            </div>
                        </div>

                        <!-- Nút tìm sân -->
                        <div class="d-grid">
                            <button type="button" class="btn btn-success btn-lg" onclick="checkAvailableFields()">
                                <i class="fas fa-search"></i> Tìm sân trống
                            </button>
                        </div>
                    </form>

                    <div id="availableFields" class="mt-4"></div>

                    <!-- ĐÁNH GIÁ -->
                    @if (Model.Reviews?.Any() == true)
                    {
                        <hr class="my-4" />
                        <h5 class="text-center fw-bold text-success-emphasis">Đánh giá từ người dùng</h5>
                        <div class="reviews-container mt-3">
                            @foreach (var r in Model.Reviews)
                            {
                                var userRating = r.Rating;
                                var userFullStars = (int)userRating;
                                var userHalfStar = userRating - userFullStars >= 0.5;

                                <div class="border p-3 mb-3 rounded shadow-sm review-card bg-white">
                                    <strong>@r.User?.UserName</strong>
                                    <div class="d-flex align-items-center mt-1">
                                        @for (int i = 0; i < userFullStars; i++)
                                        {
                                            <i class="fa fa-star text-warning"></i>
                                        }
                                        @if (userHalfStar)
                                        {
                                            <i class="fa fa-star-half-alt text-warning"></i>
                                        }
                                        @for (int i = userFullStars + (userHalfStar ? 1 : 0); i < 5; i++)
                                        {
                                            <i class="fa fa-star text-muted"></i>
                                        }
                                    </div>
                                    <em>@r.Comment</em>
                                    <div class="mt-2 text-muted small">
                                        Ngày viết: @r.CreatedAt.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-center mt-4 text-muted">Chưa có đánh giá nào.</p>
                    }
                </div>
            </div>

            <!-- PHẦN GỢI Ý CÁC SÂN KHÁC -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">Tham khảo sân khác</h5>
                        @foreach (var facility in ViewBag.OtherFacilities)
                        {
                            <div class="card border-0 shadow-sm mb-3 animate__animated animate__fadeInUp">
                                <div class="overflow-hidden">
                                    <img src="@facility.ImageUrl" class="card-img-top img-hover-zoom"
                                         style="height: 200px; object-fit: cover;" />
                                </div>
                                <div class="card-body">
                                    <h6 class="fw-bold">@facility.Name</h6>
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-geo-alt-fill text-danger"></i> @facility.Address
                                    </p>
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-clock-fill text-primary"></i> Giờ mở cửa: @facility.OpeningHours
                                    </p>
                                    <p class="text-muted small">
                                        <i class="bi bi-star-fill text-warning"></i> @facility.AverageRating.ToString("0.0") / 5.0
                                    </p>
                                    <a href="@Url.Action("Booking", "Home", new { id = facility.Id })"
                                       class="btn btn-outline-success w-100">
                                        <i class="fa fa-eye"></i> Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        function getVietnameseFieldType(fieldType) {
            switch (fieldType) {
                case "FiveArtificial":
                    return "Sân 5 người nhân tạo";
                case "SevenArtificial":
                    return "Sân 7 người nhân tạo";
                case "FiveIndoor":
                    return "Sân 5 người trong nhà";
                default:
                    return "Không xác định";
            }
        }
        function checkAvailableFields() {
            if (!document.getElementById("bookingForm").checkValidity()) {
                alert("Vui lòng điền đầy đủ thông tin!");
                return;
            }

            const date = document.getElementById("bookingDate").value;
            const start = document.getElementById("startHour").value;
            const today = new Date();
            const selectedDate = new Date(date);
            const fieldType = document.getElementById("fieldType").value;
            selectedDate.setHours(start);

            if (selectedDate < today) {
                alert("Giờ bắt đầu không khả dụng! Vui lòng chọn lại.");
                return;
            }

            const end = document.getElementById("endHour").value;

            if (parseInt(end) <= parseInt(start)) {
                alert("Giờ kết thúc phải sau giờ bắt đầu!");
                return;
            }
            if (!fieldType) {
            alert("Vui lòng chọn loại sân!");
            return;
        }
        fetch(`/Home/AvailableFields?facilityId=@Model.Id&date=${date}&startHour=${start}&endHour=${end}&fieldType=${fieldType}`)
        .then(res => res.json())
        .then(data => {
            const container = document.getElementById("availableFields");
            container.innerHTML = "";

            if (data.length === 0) {
                container.innerHTML = `
                    <div class="alert alert-warning text-center" role="alert">
                        <i class="fas fa-frown-open me-2"></i>Không có sân trống trong khung giờ này.
                    </div>`;
                return;
            }

            data.forEach(field => {
                const duration = parseInt(end) - parseInt(start);
                const price = field.pricePerHour * duration;

                container.innerHTML += `
                    <div class="card mb-4 shadow-sm animate__animated animate__fadeInUp">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="card-title mb-0">
                                    <i class="fas fa-futbol me-2 text-success"></i>${field.name}
                                    <span class="badge bg-info text-dark ms-2">${getVietnameseFieldType(field.type)}</span>
                                </h5>
                                <span class="text-muted fw-bold">${duration} giờ</span>
                            </div>
                            <ul class="list-group list-group-flush mb-3">
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>Giá mỗi giờ:</span>
                                    <strong>${field.pricePerHour.toLocaleString()} VND</strong>
                                </li>
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>Tổng tiền:</span>
                                    <strong class="text-danger">${price.toLocaleString()} VND</strong>
                                </li>
                            </ul>
                            <form asp-action="Booking" method="post">
                                <input type="hidden" name="FieldId" value="${field.id}" />
                                <input type="hidden" name="BookingDate" value="${date}" />
                                <input type="hidden" name="StartTime" value="${start}:00:00" />
                                <input type="hidden" name="EndTime" value="${end}:00:00" />
                                <button type="submit" class="btn btn-success w-100">
                                    <i class="fas fa-calendar-check me-2"></i>Đặt lịch ngay
                                </button>
                            </form>
                        </div>
                    </div>
                `;
            });
        });
        }

        const mainImage = document.querySelector(".fit"); // Ảnh chính
        const thumbnails = document.querySelectorAll(".thumbnail"); // Danh sách ảnh nhỏ

        thumbnails.forEach(thumbnail => {
            thumbnail.addEventListener("click", function () {
                mainImage.src = this.src; // Cập nhật ảnh chính
            });
        });
            function toggleFavorite(facilityId) {
            // Gửi yêu cầu tới API để thay đổi trạng thái yêu thích
            fetch(`/Home/ToggleFavorite?facilityId=${facilityId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                // Cập nhật lại icon yêu thích dựa trên trạng thái mới
                const favoriteButton = document.getElementById(`favorite-${facilityId}`);
                const icon = favoriteButton.querySelector("i");
                favoriteButton.blur();

                if (data.isFavorite) {
                    icon.classList.remove("fa-regular");
                    icon.classList.add("fa-solid");
                } else {
                    icon.classList.remove("fa-solid");
                    icon.classList.add("fa-regular");
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });
        }
    </script>
    <script>
        $(document).ready(function () {
            $('.select2').select2({
                dropdownAutoWidth: true,
                width: '100%',
                minimumResultsForSearch: Infinity, // Ẩn ô tìm kiếm nếu không cần
                dropdownCssClass: "custom-select2-dropdown"
            });
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/bookingHub")
            .build();

        connection.start();

        let selectedSlots = [];

        function selectSlot(slotKey, el) {
            if (selectedSlots.includes(slotKey)) {
                selectedSlots = selectedSlots.filter(x => x !== slotKey);
                connection.invoke("ReleaseSlot", slotKey);
                el.classList.remove("temp-locked");
            } else {
                selectedSlots.push(slotKey);
                connection.invoke("HoldSlot", slotKey);
                el.classList.add("temp-locked");
            }
        }

        connection.on("SlotLocked", function (slotKey) {
            const el = document.querySelector(`[data-slot='${slotKey}']`);
            if (el) el.classList.add("locked");
        });

        connection.on("SlotReleased", function (slotKey) {
            const el = document.querySelector(`[data-slot='${slotKey}']`);
            if (el) {
                el.classList.remove("locked");
                el.classList.remove("temp-locked");
            }
        });
    </script>

    <style>
        .select2-container--default .select2-results > .select2-results__options {
            max-height: 200px;
            overflow-y: auto;
        }

        .slot {
            padding: 10px 14px;
            border-radius: 6px;
            cursor: pointer;
            border: 1px solid #ccc;
        }

        .locked {
            background: #ccc !important;
            pointer-events: none;
        }

        .temp-locked {
            background: #28a745;
            color: white;
        }

    </style>
}
